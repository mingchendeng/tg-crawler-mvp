# Telegram API (从 https://my.telegram.org 获取)
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890
TG_PHONE=+86138xxxxxxxx

# Telegram 代理（容器内访问 Telegram 失败时可启用）
# TG_PROXY_TYPE 支持: socks5 / socks4 / http
TG_PROXY_TYPE=
TG_PROXY_HOST=
TG_PROXY_PORT=0
TG_PROXY_USERNAME=
TG_PROXY_PASSWORD=

# 监控频道（逗号分隔）
TARGET_CHANNELS=haijiaoxuanfei

# ---------- 管理后台（web 服务）----------
# JWT 签名密钥，生产环境务必改为长随机串
ADMIN_SECRET=replace-with-at-least-32-bytes-secret

# ---------- S3 / MinIO / CloudFront ----------
# 本地开发用 MinIO：S3_ENDPOINT=http://localhost:9000，桶自动创建
# 生产用 AWS S3 + CloudFront：
#   - 清空 S3_ENDPOINT/S3_ACCESS_KEY/S3_SECRET_KEY 让 boto3 使用默认凭证链（IAM role / env）
#   - S3_PUBLIC_ENDPOINT 设为 CloudFront 域名，媒体文件通过 CDN 访问
#   - 桶需提前创建好且策略只允许 CloudFront OAC 访问
S3_ENDPOINT=http://localhost:9000
S3_PUBLIC_ENDPOINT=
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tg-crawler-media-ffe95227
S3_REGION=ap-east-1

# ---------- 同人去重（DeepSeek，OpenAI 兼容 Chat Completions）----------
# API Key：https://platform.deepseek.com 创建后填入
# 关闭则不做 LLM 去重（仍会按 extracted_json 内编号 code 做快速去重）
DEDUP_LLM_ENABLED=false
# 默认 DeepSeek；若改用其它兼容网关可覆盖此 URL
DEDUP_LLM_API_URL=https://api.deepseek.com/v1/chat/completions
DEDUP_LLM_API_KEY=
# 常用：deepseek-chat（默认）；推理模型可用 deepseek-reasoner（较慢）
DEDUP_LLM_MODEL=deepseek-chat
DEDUP_LLM_TIMEOUT_SEC=60
# 与当前帖比对时，从本频道最近入库条数中取候选
DEDUP_CANDIDATE_LIMIT=40
DEDUP_MAX_TEXT_CHARS=1200
DEDUP_MAX_FIELD_JSON_CHARS=800
