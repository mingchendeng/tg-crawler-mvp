# Local deployment example (no Docker)

# Telegram
TG_API_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890
TG_PHONE=+86138xxxxxxxx
TARGET_CHANNELS=haijiaoxuanfei

# Telegram proxy (optional)
# UniClash mixed-port default can be 7994
TG_PROXY_TYPE=socks5
TG_PROXY_HOST=127.0.0.1
TG_PROXY_PORT=7994
TG_PROXY_USERNAME=
TG_PROXY_PASSWORD=

# PostgreSQL (local)
DATABASE_URL=postgresql://tguser:tgpwd@127.0.0.1:5432/tg_crawler

# S3 / MinIO / CloudFront (local 用 MinIO，生产用 AWS S3 + CloudFront)
# 本地 MinIO：桶自动创建；AWS S3：桶需提前建好，清空 ACCESS_KEY/SECRET_KEY 用 IAM 角色
# 生产环境设置 S3_PUBLIC_ENDPOINT=https://d18vwcxzwcidff.cloudfront.net 走 CDN
S3_ENDPOINT=http://127.0.0.1:9000
S3_PUBLIC_ENDPOINT=
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=tg-crawler-media-ffe95227
S3_REGION=ap-east-1

# Web admin
ADMIN_SECRET=please-change-this-to-a-long-random-string

# LLM dedupe (optional)
DEDUP_LLM_ENABLED=false
DEDUP_LLM_API_URL=
DEDUP_LLM_API_KEY=
DEDUP_LLM_MODEL=gpt-4o-mini
DEDUP_LLM_TIMEOUT_SEC=60
DEDUP_CANDIDATE_LIMIT=40
